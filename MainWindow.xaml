<Window x:Class="YGODuelSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:YGODuelSimulator"
        mc:Ignorable="d"
        Title="YGO Duel Simulator — Card Database" Height="560" Width="820">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Card Database" FontSize="20" FontWeight="SemiBold"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="ImportButton" Content="Import / Refresh Cards"
                    Padding="12,6" Click="ImportButton_Click"/>
            <TextBlock x:Name="CountText" VerticalAlignment="Center" Margin="16,0,0,0"
                       Text="Cards in database: —"/>
        </StackPanel>

        <TextBlock Grid.Row="2" x:Name="StatusText" Margin="0,12,0,0"
                   TextWrapping="Wrap" Text="Ready."/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
            <TextBlock Text="Card name:" VerticalAlignment="Center"/>
            <TextBox x:Name="CardNameBox" Width="260" Margin="8,0" Padding="4,3"
                     VerticalContentAlignment="Center" KeyDown="CardNameBox_KeyDown"/>
            <Button x:Name="ShowCardButton" Content="Show Card"
                    Padding="12,6" Click="ShowCardButton_Click"/>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="240" BorderBrush="#40808080" BorderThickness="1">
                <Image x:Name="CardImage" Stretch="Uniform"/>
            </Border>
            <TextBlock Grid.Column="1" x:Name="CardDetailsText" Margin="16,0,0,0"
                       TextWrapping="Wrap" VerticalAlignment="Top"
                       Text="Enter a card name and click Show Card."/>
        </Grid>
    </Grid>
</Window>
