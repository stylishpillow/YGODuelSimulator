<?xml version="1.0" encoding="utf-8"?>
<!-- Self-contained folder publish for 64-bit Windows. Produces a runnable app
     folder (no .NET runtime required on the target machine); this same folder is
     what the Velopack installer packages. Publish from the CLI with:
       dotnet publish -c Release /p:PublishProfile=win-x64
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <PublishDir>bin\Release\publish\win-x64\</PublishDir>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
