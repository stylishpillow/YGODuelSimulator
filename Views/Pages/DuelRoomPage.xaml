<Page x:Class="YGODuelSimulator.Views.Pages.DuelRoomPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:YGODuelSimulator.Views.Controls"
      mc:Ignorable="d"
      Title="Duel Room"
      Loaded="Page_Loaded"
      PreviewKeyDown="Page_PreviewKeyDown">
    <Page.Resources>
        <!-- The reusable card back: an orange/tan bordered card with a centre
             diamond emblem. Used for face-down cards and the Deck / Extra piles. -->
        <ControlTemplate x:Key="CardBack" TargetType="Control">
            <Border CornerRadius="5" BorderBrush="#1A0E06" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#C8783C" Offset="0"/>
                        <GradientStop Color="#8A4E23" Offset="0.5"/>
                        <GradientStop Color="#5E3216" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border Margin="5" CornerRadius="3" BorderBrush="#66FFE0B0" BorderThickness="1.5">
                    <Viewbox Margin="10">
                        <Path Data="M 50,0 L 100,50 L 50,100 L 0,50 Z" Stretch="Uniform"
                              Fill="#33200F" Stroke="#88FFE0B0" StrokeThickness="3"/>
                    </Viewbox>
                </Border>
            </Border>
        </ControlTemplate>

        <!-- A card in play: front image (rotated for defense) or the card back.
             Left-click selects / points at it; right-click opens the action menu. -->
        <DataTemplate x:Key="BoardCardTemplate">
            <Grid Width="82" Height="120" Cursor="Hand" Background="Transparent"
                  ToolTip="{Binding Name}" RenderTransformOrigin="0.5,0.5"
                  MouseLeftButtonUp="Card_Click"
                  MouseRightButtonUp="Card_RightClick">
                <Grid.RenderTransform>
                    <RotateTransform Angle="{Binding Rotation}"/>
                </Grid.RenderTransform>
                <!-- FallbackValue keeps empty zones (null data context) blank: the
                     ContentControl still realises this template, so without it the
                     card back and selection outline would default to Visible. -->
                <Image Source="{Binding Image}" Stretch="Uniform"
                       Visibility="{Binding FrontVisibility, FallbackValue=Collapsed}"/>
                <Control Template="{StaticResource CardBack}"
                         Visibility="{Binding BackVisibility, FallbackValue=Collapsed}"/>
                <!-- Tokens have no artwork; show a labelled placeholder when face-up. -->
                <Border Visibility="{Binding TokenVisibility, FallbackValue=Collapsed}"
                        CornerRadius="5" Background="#3A5A3A" BorderBrush="#88BFE0BF" BorderThickness="1.5">
                    <TextBlock Text="TOKEN" Foreground="#DDEFFFEF" FontWeight="Bold" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <!-- Selection outline -->
                <Border Visibility="{Binding SelectionVisibility, FallbackValue=Collapsed}" CornerRadius="5"
                        BorderBrush="#FFE64A" BorderThickness="3" IsHitTestVisible="False"/>
                <!-- "Pointing" / "declaring" ring -->
                <Border Visibility="{Binding PointVisibility, FallbackValue=Collapsed}" CornerRadius="6"
                        BorderBrush="#33E1FF" BorderThickness="4" Margin="-3" IsHitTestVisible="False"/>
                <!-- Counter tally badge -->
                <Border Visibility="{Binding CounterVisibility, FallbackValue=Collapsed}"
                        Width="24" Height="24" CornerRadius="12" Background="#DD1E90FF"
                        BorderBrush="White" BorderThickness="1.5"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-6,0"
                        IsHitTestVisible="False">
                    <TextBlock Text="{Binding Counters}" Foreground="White" FontSize="12" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <!-- "Revealed to opponent" marker -->
                <Border Visibility="{Binding RevealVisibility, FallbackValue=Collapsed}"
                        Width="20" Height="20" CornerRadius="10" Background="#DD37C6FF"
                        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-5,-5,0,0"
                        IsHitTestVisible="False">
                    <TextBlock Text="👁" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- A display-only card for the reveal viewer. It shows a detached snapshot of
             the cards the opponent is revealing (their hand or a single card), which
             must not be selectable or actionable. So: no click handlers and none of
             the field overlays (selection / point / reveal marker). The pile viewer,
             by contrast, keeps the interactive BoardCardTemplate because clicking a
             card there selects the real card to act on it (e.g. Special Summon). -->
        <DataTemplate x:Key="ViewerCardTemplate">
            <Grid Width="82" Height="120" Background="Transparent" ToolTip="{Binding Name}">
                <Image Source="{Binding Image}" Stretch="Uniform"
                       Visibility="{Binding FrontVisibility, FallbackValue=Collapsed}"/>
                <Control Template="{StaticResource CardBack}"
                         Visibility="{Binding BackVisibility, FallbackValue=Collapsed}"/>
                <!-- Tokens have no artwork; show a labelled placeholder when face-up. -->
                <Border Visibility="{Binding TokenVisibility, FallbackValue=Collapsed}"
                        CornerRadius="5" Background="#3A5A3A" BorderBrush="#88BFE0BF" BorderThickness="1.5">
                    <TextBlock Text="TOKEN" Foreground="#DDEFFFEF" FontWeight="Bold" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- A single-card zone: a click target tinted by zone type, with a faint
             watermark label. Highlights green while it's a valid placement target. -->
        <DataTemplate x:Key="ZoneTemplate">
            <Border Width="88" Height="126" Margin="4" CornerRadius="5"
                    MouseLeftButtonUp="Zone_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#0AFFFFFF"/>
                        <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                        <Setter Property="BorderThickness" Value="1.5"/>
                        <Style.Triggers>
                            <!-- Monster zones: amber -->
                            <DataTrigger Binding="{Binding Kind}" Value="MainMonster">
                                <Setter Property="Background" Value="#1FE0912E"/>
                                <Setter Property="BorderBrush" Value="#99E0912E"/>
                            </DataTrigger>
                            <!-- Extra Monster zones: blue -->
                            <DataTrigger Binding="{Binding Kind}" Value="ExtraMonster">
                                <Setter Property="Background" Value="#224E7BE0"/>
                                <Setter Property="BorderBrush" Value="#AA5E8BF0"/>
                            </DataTrigger>
                            <!-- Spell/Trap zones: green -->
                            <DataTrigger Binding="{Binding Kind}" Value="SpellTrap">
                                <Setter Property="Background" Value="#1F26B37A"/>
                                <Setter Property="BorderBrush" Value="#9930C98A"/>
                            </DataTrigger>
                            <!-- Field zone: purple -->
                            <DataTrigger Binding="{Binding Kind}" Value="Field">
                                <Setter Property="Background" Value="#22A64AC8"/>
                                <Setter Property="BorderBrush" Value="#AAB85AD8"/>
                            </DataTrigger>
                            <!-- Valid placement target: green glow (wins over tint) -->
                            <DataTrigger Binding="{Binding IsTarget}" Value="True">
                                <Setter Property="Background" Value="#3341FF7A"/>
                                <Setter Property="BorderBrush" Value="#FF41FF7A"/>
                                <Setter Property="BorderThickness" Value="2.5"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <TextBlock Text="{Binding Label}" Opacity="0.4" FontSize="10" FontWeight="SemiBold"
                               Foreground="White" TextAlignment="Center" TextWrapping="Wrap"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <!-- The opponent's cards are turned 180° to face away from us, the
                         way they would across a table. Combines with the card's own
                         defense rotation inside the template. -->
                    <ContentControl Content="{Binding Card}"
                                    ContentTemplate="{StaticResource BoardCardTemplate}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    RenderTransformOrigin="0.5,0.5">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOpponent}" Value="True">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value><RotateTransform Angle="180"/></Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Count-pile (GY / Banished) look. -->
        <Style x:Key="PileBorder" TargetType="Border">
            <Setter Property="Width" Value="88"/>
            <Setter Property="Height" Value="126"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>

        <!-- Hand strip of cards. -->
        <ItemsPanelTemplate x:Key="HorizontalHand">
            <StackPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>

        <!-- A player portrait: initial-avatar, name, LP, and a status emote badge /
             label the opponent can see (bound to a PlayerBoard). -->
        <DataTemplate x:Key="PortraitTemplate">
            <Border Background="#18FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                    CornerRadius="8" Padding="8">
                <StackPanel Orientation="Horizontal">
                    <Grid Width="46" Height="46">
                        <Ellipse Fill="#2E6BB0" Stroke="#66BFE8FF" StrokeThickness="1.5"/>
                        <TextBlock Text="{Binding Initial}" Foreground="White" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <!-- Emote glyph badge over the avatar -->
                        <Border Visibility="{Binding EmoteVisibility}" Width="24" Height="24" CornerRadius="12"
                                Background="#F01C2A3A" BorderBrush="#88BFE8FF" BorderThickness="1"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4">
                            <TextBlock Text="{Binding EmoteGlyph}" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="SemiBold"
                                   FontSize="14" TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                        <TextBlock Foreground="#AACFE8FF" FontSize="12">
                            <Run Text="LP "/><Run Text="{Binding LifePoints}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding EmoteLabel}" Foreground="#FFD27A" FontSize="11"
                                   FontWeight="SemiBold" Visibility="{Binding EmoteVisibility}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- One line of the game log: dim timestamp + text; chat lines are brighter. -->
        <DataTemplate x:Key="LogEntryTemplate">
            <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,1">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <!-- Base colour as a Setter (not a local attribute on the TextBlock),
                             so the Player/Opponent triggers below can override it — a local
                             value would outrank the triggers and defeat the colour-coding. -->
                        <Setter Property="Foreground" Value="#C6D2DC"/>
                        <Style.Triggers>
                            <!-- Lines are colour-coded by side: the local player blue, the
                                 opponent red (both actions and chat); system lines stay grey. -->
                            <DataTrigger Binding="{Binding Side}" Value="Player">
                                <Setter Property="Foreground" Value="#6FB4FF"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Side}" Value="Opponent">
                                <Setter Property="Foreground" Value="#FF7A7A"/>
                            </DataTrigger>
                            <!-- Chat is emphasised so it reads apart from action lines. -->
                            <DataTrigger Binding="{Binding Chat}" Value="True">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <Run Text="{Binding Time, Mode=OneWay}" FontSize="10" Foreground="#6FAFC4D4"/>
                <Run Text="  "/><Run Text="{Binding Text, Mode=OneWay}"/>
            </TextBlock>
        </DataTemplate>

        <!-- Overlay for a shared Extra Monster Zone: the opponent's half of the cell,
             drawn on top of the player's zone. It only appears when the opponent has a
             card there (or is targeting it), so an empty overlay never hides the
             player's own card or blocks the player's drop underneath. -->
        <DataTemplate x:Key="ExtraOverlayTemplate">
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Card}" Value="{x:Null}"/>
                                    <Condition Binding="{Binding IsTarget}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource ZoneTemplate}"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="RootGrid" Margin="16,0,16,0" VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ui:CardControl Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <!-- Line 1: decks + turn / phase -->
                <WrapPanel Orientation="Horizontal">
                    <ComboBox x:Name="DeckPicker" Width="150" VerticalAlignment="Center"/>
                    <ui:Button x:Name="LoadPlayerBtn" Content="Load → Player" Margin="6,0,0,0" Click="LoadPlayer_Click"/>
                    <ui:Button x:Name="LoadOpponentBtn" Content="Load → Opponent" Margin="6,0,0,0" Click="LoadOpponent_Click"/>

                    <Border Width="1" Background="#40FFFFFF" Margin="14,2,14,2"/>

                    <TextBlock Text="{Binding TurnSummary}" VerticalAlignment="Center"
                               FontWeight="SemiBold" FontSize="14"/>
                    <ui:Button Content="Next Phase" Margin="12,0,0,0" Click="NextPhase_Click"/>
                    <ui:Button Content="End Turn" Margin="6,0,0,0" Appearance="Primary" Click="EndTurn_Click"/>
                </WrapPanel>

                <!-- Line 2: active-player actions + LP + dice -->
                <WrapPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <ui:Button Content="Draw" Click="Draw_Click"/>
                    <ui:Button Content="Shuffle deck" Margin="6,0,0,0" Click="Shuffle_Click"/>
                    <ui:Button Content="Token" Margin="6,0,0,0" Click="CreateToken_Click"/>
                    <ui:Button Content="Reveal hand" Margin="6,0,0,0" Click="RevealHand_Click"/>
                    <ui:Button Content="Discard random" Margin="6,0,0,0" Click="DiscardRandom_Click"/>

                    <Border Width="1" Background="#40FFFFFF" Margin="14,2,14,2"/>

                    <TextBlock Text="P LP" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"/>
                    <ui:TextBox Width="64" Text="{Binding Player.LifePoints, Mode=TwoWay}"/>
                    <ui:Button Content="−1000" Margin="4,0,0,0" Click="PlayerLpMinus1000_Click"/>
                    <ui:Button Content="−500" Margin="4,0,0,0" Click="PlayerLpMinus500_Click"/>

                    <TextBlock Text="O LP" VerticalAlignment="Center" Margin="14,0,4,0" FontWeight="SemiBold"/>
                    <ui:TextBox x:Name="OppLpBox" Width="64" Text="{Binding Opponent.LifePoints, Mode=TwoWay}"/>
                    <ui:Button x:Name="OppLpMinus1000Btn" Content="−1000" Margin="4,0,0,0" Click="OppLpMinus1000_Click"/>
                    <ui:Button x:Name="OppLpMinus500Btn" Content="−500" Margin="4,0,0,0" Click="OppLpMinus500_Click"/>

                    <Border Width="1" Background="#40FFFFFF" Margin="14,2,14,2"/>

                    <ui:Button Content="Roll die" Click="Die_Click"/>
                    <ui:Button Content="Flip coin" Margin="6,0,0,0" Click="Coin_Click"/>
                    <TextBlock x:Name="ResultText" VerticalAlignment="Center" Margin="12,0,0,0"
                               FontWeight="SemiBold"/>
                </WrapPanel>
            </StackPanel>
        </ui:CardControl>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Field (centre, flanked by the inspector and the log) -->
            <Grid Grid.Column="1" Margin="10,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Opponent's hand + portrait (docked to the deck/GY side). -->
                <Border Grid.Row="0" Background="#14FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                        CornerRadius="4" Margin="0,0,0,6" MinHeight="90">
                    <DockPanel>
                        <ContentControl DockPanel.Dock="Right" Content="{Binding Opponent}"
                                        ContentTemplate="{StaticResource PortraitTemplate}"
                                        VerticalAlignment="Center" Margin="8,4"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal" Margin="6">
                                <TextBlock Text="Opp hand" Foreground="#99FFFFFF" VerticalAlignment="Center"
                                           Margin="0,0,8,0" FontSize="11"/>
                                <ItemsControl ItemsSource="{Binding Opponent.Hand}" ItemTemplate="{StaticResource BoardCardTemplate}"
                                              ItemsPanel="{StaticResource HorizontalHand}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Playmat: opponent half (top) and player half (bottom), extra
                     monster zones meeting in the middle. Clicking bare felt cancels. -->
                <Border Grid.Row="1" CornerRadius="8" Padding="16" MouseLeftButtonUp="Playmat_Click">
                    <Border.Background>
                        <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.75" RadiusY="0.85">
                            <GradientStop Color="#1E3A2A" Offset="0"/>
                            <GradientStop Color="#12241A" Offset="1"/>
                        </RadialGradientBrush>
                    </Border.Background>
                    <Grid x:Name="PlaymatArea">
                    <Viewbox Stretch="Uniform">
                        <StackPanel>
                            <!-- Opponent half: S/T row (top), then monster row (adjacent to
                                 the shared centre band). Banished sits beside the GY. -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96"/><ColumnDefinition Width="96"/><ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="96"/><ColumnDefinition Width="96"/><ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="96"/><ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- S/T row -->
                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PileBorder}" Tag="o:extra" MouseLeftButtonUp="Pile_Click">
                                    <Grid>
                                        <Control Template="{StaticResource CardBack}" Margin="6"/>
                                        <Border VerticalAlignment="Bottom" Background="#B0000000" CornerRadius="0,0,4,4">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Extra" HorizontalAlignment="Center" FontSize="10" Foreground="White"/>
                                                <TextBlock Text="{Binding Opponent.ExtraDeck.Count}" HorizontalAlignment="Center" FontSize="16" Foreground="White"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                                <ContentControl Grid.Row="0" Grid.Column="1" Content="{Binding Opponent.SpellTrapZones[0]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="0" Grid.Column="2" Content="{Binding Opponent.SpellTrapZones[1]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="0" Grid.Column="3" Content="{Binding Opponent.SpellTrapZones[2]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="0" Grid.Column="4" Content="{Binding Opponent.SpellTrapZones[3]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="0" Grid.Column="5" Content="{Binding Opponent.SpellTrapZones[4]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <Border Grid.Row="0" Grid.Column="6" Style="{StaticResource PileBorder}" Tag="o:deck"
                                        MouseLeftButtonUp="Pile_Click" MouseRightButtonUp="Deck_RightClick">
                                    <Grid>
                                        <Control Template="{StaticResource CardBack}" Margin="6"/>
                                        <Border VerticalAlignment="Bottom" Background="#B0000000" CornerRadius="0,0,4,4">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Deck" HorizontalAlignment="Center" FontSize="10" Foreground="White"/>
                                                <TextBlock Text="{Binding Opponent.Deck.Count}" HorizontalAlignment="Center" FontSize="16" Foreground="White"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Monster row -->
                                <ContentControl Grid.Row="1" Grid.Column="0" Content="{Binding Opponent.FieldZone}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding Opponent.MainMonsterZones[0]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="1" Grid.Column="2" Content="{Binding Opponent.MainMonsterZones[1]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="1" Grid.Column="3" Content="{Binding Opponent.MainMonsterZones[2]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="1" Grid.Column="4" Content="{Binding Opponent.MainMonsterZones[3]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="1" Grid.Column="5" Content="{Binding Opponent.MainMonsterZones[4]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <Border Grid.Row="1" Grid.Column="6" Style="{StaticResource PileBorder}" Tag="o:gy" MouseLeftButtonUp="Pile_Click">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="GY" HorizontalAlignment="Center" FontSize="11"/>
                                        <TextBlock Text="{Binding Opponent.Graveyard.Count}" HorizontalAlignment="Center" FontSize="20"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="7" Style="{StaticResource PileBorder}" Tag="o:ban" MouseLeftButtonUp="Pile_Click">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="Banish" HorizontalAlignment="Center" FontSize="11"/>
                                        <TextBlock Text="{Binding Opponent.Banished.Count}" HorizontalAlignment="Center" FontSize="20"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Shared centre band: the two Extra Monster Zones, used by both
                                 players. Each cell is the player's zone with the opponent's
                                 zone overlaid (the overlay shows only when they occupy it). -->
                            <Grid Margin="0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96"/><ColumnDefinition Width="96"/><ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="96"/><ColumnDefinition Width="96"/><ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="96"/><ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="2">
                                    <ContentControl Content="{Binding Player.ExtraMonsterZones[0]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                    <ContentControl Content="{Binding Opponent.ExtraMonsterZones[0]}" ContentTemplate="{StaticResource ExtraOverlayTemplate}"/>
                                </Grid>
                                <Grid Grid.Column="4">
                                    <ContentControl Content="{Binding Player.ExtraMonsterZones[1]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                    <ContentControl Content="{Binding Opponent.ExtraMonsterZones[1]}" ContentTemplate="{StaticResource ExtraOverlayTemplate}"/>
                                </Grid>
                            </Grid>

                            <!-- Player half: monster row (adjacent to the centre band), then
                                 S/T row. Banished sits beside the GY. -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96"/><ColumnDefinition Width="96"/><ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="96"/><ColumnDefinition Width="96"/><ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="96"/><ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Monster row -->
                                <ContentControl Grid.Row="0" Grid.Column="0" Content="{Binding Player.FieldZone}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="0" Grid.Column="1" Content="{Binding Player.MainMonsterZones[0]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="0" Grid.Column="2" Content="{Binding Player.MainMonsterZones[1]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="0" Grid.Column="3" Content="{Binding Player.MainMonsterZones[2]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="0" Grid.Column="4" Content="{Binding Player.MainMonsterZones[3]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="0" Grid.Column="5" Content="{Binding Player.MainMonsterZones[4]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <Border Grid.Row="0" Grid.Column="6" Style="{StaticResource PileBorder}" Tag="p:gy" MouseLeftButtonUp="Pile_Click">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="GY" HorizontalAlignment="Center" FontSize="11"/>
                                        <TextBlock Text="{Binding Player.Graveyard.Count}" HorizontalAlignment="Center" FontSize="20"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="7" Style="{StaticResource PileBorder}" Tag="p:ban" MouseLeftButtonUp="Pile_Click">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="Banish" HorizontalAlignment="Center" FontSize="11"/>
                                        <TextBlock Text="{Binding Player.Banished.Count}" HorizontalAlignment="Center" FontSize="20"/>
                                    </StackPanel>
                                </Border>

                                <!-- S/T row -->
                                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PileBorder}" Tag="p:extra" MouseLeftButtonUp="Pile_Click">
                                    <Grid>
                                        <Control Template="{StaticResource CardBack}" Margin="6"/>
                                        <Border VerticalAlignment="Bottom" Background="#B0000000" CornerRadius="0,0,4,4">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Extra" HorizontalAlignment="Center" FontSize="10" Foreground="White"/>
                                                <TextBlock Text="{Binding Player.ExtraDeck.Count}" HorizontalAlignment="Center" FontSize="16" Foreground="White"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                                <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding Player.SpellTrapZones[0]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="1" Grid.Column="2" Content="{Binding Player.SpellTrapZones[1]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="1" Grid.Column="3" Content="{Binding Player.SpellTrapZones[2]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="1" Grid.Column="4" Content="{Binding Player.SpellTrapZones[3]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <ContentControl Grid.Row="1" Grid.Column="5" Content="{Binding Player.SpellTrapZones[4]}" ContentTemplate="{StaticResource ZoneTemplate}"/>
                                <Border Grid.Row="1" Grid.Column="6" Style="{StaticResource PileBorder}" Tag="p:deck"
                                        MouseLeftButtonUp="Pile_Click" MouseRightButtonUp="Deck_RightClick">
                                    <Grid>
                                        <Control Template="{StaticResource CardBack}" Margin="6"/>
                                        <Border VerticalAlignment="Bottom" Background="#B0000000" CornerRadius="0,0,4,4">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="Deck" HorizontalAlignment="Center" FontSize="10" Foreground="White"/>
                                                <TextBlock Text="{Binding Player.Deck.Count}" HorizontalAlignment="Center" FontSize="16" Foreground="White"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Viewbox>

                    <!-- Table-talk banner (declare / point) -->
                    <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,10,0,0"
                            Background="#E6123A5A" BorderBrush="#66BFE8FF" BorderThickness="1"
                            CornerRadius="14" Padding="18,7" Panel.ZIndex="10" IsHitTestVisible="False"
                            Visibility="{Binding AnnouncementVisibility}">
                        <TextBlock Text="{Binding Announcement}" Foreground="White"
                                   FontWeight="SemiBold" FontSize="14"/>
                    </Border>

                    <!-- Attack-declaration arrows are drawn here, over the whole board. -->
                    <Canvas x:Name="ArrowOverlay" IsHitTestVisible="False" Panel.ZIndex="20"/>
                    </Grid>
                </Border>

                <!-- Player's hand + portrait & status-emote buttons (docked to the deck/GY side). -->
                <Border Grid.Row="2" Background="#14FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                        CornerRadius="4" Margin="0,6,0,0" MinHeight="134">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="8,0">
                            <ContentControl Content="{Binding Player}" ContentTemplate="{StaticResource PortraitTemplate}"
                                            VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                                <ui:Button Content="🤔 Thinking" Tag="thinking" Click="Emote_Click"
                                           HorizontalAlignment="Stretch" Margin="0,0,0,4" ToolTip="Thinking"/>
                                <ui:Button Content="👍 OK" Tag="ok" Click="Emote_Click"
                                           HorizontalAlignment="Stretch" Margin="0,0,0,4" ToolTip="OK / acknowledge"/>
                                <ui:Button Content="✋ Respond" Tag="respond" Click="Emote_Click"
                                           HorizontalAlignment="Stretch" ToolTip="I want to respond"/>
                            </StackPanel>
                        </StackPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Player.Hand}" ItemTemplate="{StaticResource BoardCardTemplate}"
                                          ItemsPanel="{StaticResource HorizontalHand}" Margin="6"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Card inspector (left flank) -->
            <controls:CardPreview x:Name="Preview" Grid.Column="0"/>

            <!-- Right: timestamped action + chat log with a chat input. -->
            <Border Grid.Column="2" Margin="12,0,0,0" Background="#12FFFFFF"
                    BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="8">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Game log" Foreground="#AACFE8FF"
                               FontWeight="SemiBold" FontSize="13" Margin="2,0,0,6"/>

                    <ScrollViewer x:Name="LogScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="LogItems" ItemsSource="{Binding LogEntries}"
                                      ItemTemplate="{StaticResource LogEntryTemplate}"/>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="ChatInput" Grid.Column="0" PlaceholderText="Type a message…"
                                    KeyDown="ChatInput_KeyDown"/>
                        <ui:Button Grid.Column="1" Content="Send" Margin="4,0,0,0" Click="SendChat_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- View menu: opens at the cursor on LEFT-click — the table-talk actions of
             a two-player game (like Dueling Book's card menu). -->
        <Popup x:Name="ViewMenu" StaysOpen="False" AllowsTransparency="True"
               Placement="MousePoint" PopupAnimation="Fade">
            <Border Background="#F0202020" BorderBrush="#60FFFFFF" BorderThickness="1"
                    CornerRadius="6" Padding="6">
                <StackPanel Width="150">
                    <TextBlock Text="CARD" Foreground="#8AA" Margin="4,2" FontSize="10" FontWeight="Bold"/>
                    <ui:Button Content="Inspect" HorizontalAlignment="Stretch" Margin="0,2" Click="Inspect_Click"/>
                    <ui:Button x:Name="RevealButton" Content="Reveal to opponent" HorizontalAlignment="Stretch" Margin="0,2" Click="Reveal_Click"/>
                    <ui:Button Content="Declare Effect" HorizontalAlignment="Stretch" Margin="0,2" Click="DeclareEffect_Click"/>
                    <ui:Button Content="Point" HorizontalAlignment="Stretch" Margin="0,2" Click="Point_Click"/>
                    <ui:Button Content="Declare Attack" HorizontalAlignment="Stretch" Margin="0,2" Click="DeclareAttack_Click"/>
                    <ui:Button Content="Declare Direct Attack" HorizontalAlignment="Stretch" Margin="0,2" Click="DeclareDirectAttack_Click"/>
                    <ui:Button Content="Swap Control" HorizontalAlignment="Stretch" Margin="0,2" Click="SwapControl_Click"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Action menu: opens at the cursor on right-click. Placement actions arm a
             target and let the player click the destination zone; the rest run now. -->
        <Popup x:Name="CardActions" StaysOpen="False" AllowsTransparency="True"
               Placement="MousePoint" PopupAnimation="Fade">
            <Border Background="#F0202020" BorderBrush="#60FFFFFF" BorderThickness="1"
                    CornerRadius="6" Padding="6">
                <StackPanel Width="160">
                    <TextBlock Text="PLACE" Foreground="#8AA" Margin="4,2" FontSize="10" FontWeight="Bold"/>
                    <ui:Button Content="Normal Summon (ATK)" HorizontalAlignment="Stretch" Margin="0,2" Click="Summon_Click"/>
                    <ui:Button Content="Normal Set (DEF)" HorizontalAlignment="Stretch" Margin="0,2" Click="SetMonster_Click"/>
                    <ui:Button Content="Special Summon (ATK)" HorizontalAlignment="Stretch" Margin="0,2" Click="SpecialAtk_Click"/>
                    <ui:Button Content="Special Summon (DEF)" HorizontalAlignment="Stretch" Margin="0,2" Click="SpecialDef_Click"/>
                    <ui:Button Content="Activate S/T" HorizontalAlignment="Stretch" Margin="0,2" Click="ActivateST_Click"/>
                    <ui:Button Content="Set S/T" HorizontalAlignment="Stretch" Margin="0,2" Click="SetST_Click"/>
                    <ui:Button Content="Field Spell" HorizontalAlignment="Stretch" Margin="0,2" Click="FieldSpell_Click"/>

                    <TextBlock Text="POSITION" Foreground="#8AA" Margin="4,6,4,2" FontSize="10" FontWeight="Bold"/>
                    <ui:Button Content="To Attack" HorizontalAlignment="Stretch" Margin="0,2" Click="SelAttack_Click"/>
                    <ui:Button Content="To Defense" HorizontalAlignment="Stretch" Margin="0,2" Click="SelDefense_Click"/>
                    <ui:Button Content="Flip Summon" HorizontalAlignment="Stretch" Margin="0,2" Click="SelFlipSummon_Click"/>
                    <ui:Button Content="Flip" HorizontalAlignment="Stretch" Margin="0,2" Click="SelFlip_Click"/>

                    <TextBlock Text="COUNTERS" Foreground="#8AA" Margin="4,6,4,2" FontSize="10" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="− Counter" Width="76" Margin="0,2,2,2" Click="RemoveCounter_Click"/>
                        <ui:Button Content="+ Counter" Width="76" Margin="2,2,0,2" Click="AddCounter_Click"/>
                    </StackPanel>

                    <TextBlock Text="MOVE" Foreground="#8AA" Margin="4,6,4,2" FontSize="10" FontWeight="Bold"/>
                    <ui:Button Content="To Hand" HorizontalAlignment="Stretch" Margin="0,2" Click="SelToHand_Click"/>
                    <ui:Button Content="To Graveyard" HorizontalAlignment="Stretch" Margin="0,2" Click="SelToGrave_Click"/>
                    <ui:Button Content="Banish" HorizontalAlignment="Stretch" Margin="0,2" Click="SelToBanish_Click"/>
                    <ui:Button Content="To Deck (top)" HorizontalAlignment="Stretch" Margin="0,2" Click="SelToDeckTop_Click"/>
                    <ui:Button Content="To Deck (bottom)" HorizontalAlignment="Stretch" Margin="0,2" Click="SelToDeckBottom_Click"/>
                    <ui:Button Content="To Extra Deck" HorizontalAlignment="Stretch" Margin="0,2" Click="SelToExtra_Click"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Deck action menu: opens at the cursor on right-click of a deck pile,
             styled to match the card menus above. Shuffle acts on the clicked deck;
             the surrender actions (own deck only) end the duel. -->
        <Popup x:Name="DeckActions" StaysOpen="False" AllowsTransparency="True"
               Placement="MousePoint" PopupAnimation="Fade">
            <Border Background="#F0202020" BorderBrush="#60FFFFFF" BorderThickness="1"
                    CornerRadius="6" Padding="6">
                <StackPanel Width="160">
                    <StackPanel x:Name="DeckPlayGroup">
                        <TextBlock Text="DECK" Foreground="#8AA" Margin="4,2" FontSize="10" FontWeight="Bold"/>
                        <ui:Button Content="Shuffle" HorizontalAlignment="Stretch" Margin="0,2" Click="DeckShuffle_Click"/>
                        <ui:Button Content="Mill top → GY" HorizontalAlignment="Stretch" Margin="0,2" Click="DeckMillTop_Click"/>
                        <ui:Button Content="Mill bottom → GY" HorizontalAlignment="Stretch" Margin="0,2" Click="DeckMillBottom_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="DeckSurrenderGroup">
                        <TextBlock Text="SURRENDER" Foreground="#8AA" Margin="4,6,4,2" FontSize="10" FontWeight="Bold"/>
                        <ui:Button Content="Concede" HorizontalAlignment="Stretch" Margin="0,2" Click="Concede_Click"/>
                        <ui:Button Content="Admit defeat" HorizontalAlignment="Stretch" Margin="0,2" Click="AdmitDefeat_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Pile viewer (Deck / Extra / GY / Banished contents) -->
        <Popup x:Name="PileViewer" Placement="Center" StaysOpen="False" AllowsTransparency="True">
            <Border Background="#F0202020" BorderBrush="#60FFFFFF" BorderThickness="1"
                    CornerRadius="6" Padding="12" MaxWidth="760">
                <DockPanel>
                    <TextBlock x:Name="PileViewerTitle" DockPanel.Dock="Top" FontSize="16"
                               FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="470" Width="720">
                        <ItemsControl x:Name="PileViewerItems" ItemTemplate="{StaticResource BoardCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Popup>

        <!-- Reveal viewer: what the opponent is showing you (single card or hand). -->
        <Popup x:Name="RevealViewer" Placement="Center" StaysOpen="False" AllowsTransparency="True">
            <Border Background="#F0202020" BorderBrush="#60BFE8FF" BorderThickness="1"
                    CornerRadius="6" Padding="12" MaxWidth="760">
                <DockPanel>
                    <TextBlock x:Name="RevealViewerTitle" DockPanel.Dock="Top" FontSize="16"
                               FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="470" Width="720">
                        <ItemsControl x:Name="RevealViewerItems" ItemTemplate="{StaticResource ViewerCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Popup>

        <!-- Pre-game overlay: pick practice vs online, then the lobby / deck / RPS /
             turn-order flow. Hidden once a duel is underway. -->
        <Border x:Name="Overlay" Grid.Row="0" Grid.RowSpan="2" Background="#F00B0E14" Panel.ZIndex="50">
            <Border Background="#161B26" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="12"
                    Padding="28" MinWidth="420" MaxWidth="520"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <!-- Entry -->
                    <StackPanel x:Name="EntryPanel">
                        <TextBlock Text="Duel Room" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Duel someone over the Internet, play across your local network, or practice offline."
                                   Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center" Margin="0,6,0,20"/>
                        <ui:Button Content="Play online" Appearance="Primary" HorizontalAlignment="Stretch"
                                   Margin="0,0,0,10" Click="PlayInternet_Click"/>
                        <ui:Button Content="Play on your network (LAN)" HorizontalAlignment="Stretch"
                                   Margin="0,0,0,10" Click="PlayLan_Click"/>
                        <ui:Button Content="Practice offline" HorizontalAlignment="Stretch" Click="Practice_Click"/>
                    </StackPanel>

                    <!-- Online (Internet, via room code) -->
                    <StackPanel x:Name="InternetPanel" Visibility="Collapsed">
                        <TextBlock Text="Play online" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Host a game to get a room code, or enter the code your opponent shared."
                                   Opacity="0.7" TextWrapping="Wrap" Margin="0,4,0,14"/>
                        <ui:Button Content="Host a game" Appearance="Primary" HorizontalAlignment="Stretch"
                                   Click="HostInternet_Click"/>
                        <TextBlock Text="or join with a code" Opacity="0.6" Margin="0,16,0,6"
                                   FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="RoomCodeBox" Grid.Column="0" PlaceholderText="Room code"
                                        CharacterCasing="Upper" MaxLength="12" Margin="0,0,8,0"
                                        KeyDown="RoomCodeBox_KeyDown"/>
                            <ui:Button x:Name="JoinCodeButton" Grid.Column="1" Content="Join"
                                       Click="JoinInternet_Click"/>
                        </Grid>
                        <ui:Button Content="Back" HorizontalAlignment="Left" Margin="0,16,0,0" Click="BackToEntry_Click"/>
                    </StackPanel>

                    <!-- Lobby -->
                    <StackPanel x:Name="LobbyPanel" Visibility="Collapsed">
                        <TextBlock Text="LAN games" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Create a room others can join, or pick one below."
                                   Opacity="0.7" Margin="0,4,0,14"/>
                        <ui:Button Content="Create room" Appearance="Primary" HorizontalAlignment="Stretch"
                                   Click="CreateRoom_Click"/>
                        <TextBlock Text="Rooms on your network" Opacity="0.6" Margin="0,16,0,6"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <Border MinHeight="80" Background="#0DFFFFFF" CornerRadius="6" Padding="6">
                            <Grid>
                                <ItemsControl x:Name="RoomsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2,3">
                                                <TextBlock Text="{Binding HostName}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                <ui:Button Content="Join" HorizontalAlignment="Right" Tag="{Binding}" Click="JoinRoom_Click"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="NoRoomsText" Text="Searching…" Opacity="0.5"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ui:Button Content="Back" HorizontalAlignment="Left" Margin="0,14,0,0" Click="BackToEntry_Click"/>
                    </StackPanel>

                    <!-- Connecting -->
                    <StackPanel x:Name="ConnectingPanel" Visibility="Collapsed">
                        <TextBlock x:Name="ConnectingText" Text="Connecting…" FontSize="18" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                        <ui:Button Content="Cancel" HorizontalAlignment="Center" Margin="0,18,0,0" Click="BackToEntry_Click"/>
                    </StackPanel>

                    <!-- Deck select -->
                    <StackPanel x:Name="DeckPanel" Visibility="Collapsed">
                        <TextBlock x:Name="DeckOppText" Text="Connected." FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Choose your deck" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <ComboBox x:Name="OnlineDeckPicker" Margin="0,12,0,0" HorizontalAlignment="Stretch"/>
                        <ui:Button x:Name="ReadyButton" Content="Ready" Appearance="Primary"
                                   HorizontalAlignment="Stretch" Margin="0,12,0,0" Click="ReadyDeck_Click"/>
                        <TextBlock x:Name="DeckStatusText" Opacity="0.7" HorizontalAlignment="Center"
                                   Margin="0,12,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>

                    <!-- Rock-paper-scissors -->
                    <StackPanel x:Name="RpsPanel" Visibility="Collapsed">
                        <TextBlock Text="Rock · Paper · Scissors" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Winner decides who goes first." Opacity="0.7"
                                   HorizontalAlignment="Center" Margin="0,4,0,16"/>
                        <StackPanel x:Name="RpsButtons" Orientation="Horizontal" HorizontalAlignment="Center">
                            <ui:Button Content="✊ Rock" Margin="4" Click="RpsRock_Click"/>
                            <ui:Button Content="✋ Paper" Margin="4" Click="RpsPaper_Click"/>
                            <ui:Button Content="✌ Scissors" Margin="4" Click="RpsScissors_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="RpsStatusText" HorizontalAlignment="Center" Margin="0,16,0,0"
                                   FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>

                    <!-- Choose order -->
                    <StackPanel x:Name="OrderPanel" Visibility="Collapsed">
                        <TextBlock x:Name="OrderText" FontSize="18" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                        <StackPanel x:Name="OrderButtons" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <ui:Button Content="Go first" Appearance="Primary" Margin="4" Click="GoFirst_Click"/>
                            <ui:Button Content="Go second" Margin="4" Click="GoSecond_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Disconnected -->
                    <StackPanel x:Name="DisconnectedPanel" Visibility="Collapsed">
                        <TextBlock x:Name="DisconnectedText" FontSize="16" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                        <ui:Button Content="Back to menu" HorizontalAlignment="Center" Margin="0,16,0,0" Click="BackToEntry_Click"/>
                    </StackPanel>

                    <!-- Duel over: result + rematch / quit -->
                    <StackPanel x:Name="EndPanel" Visibility="Collapsed">
                        <TextBlock Text="Duel over" Opacity="0.6" HorizontalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="EndResultText" FontSize="30" FontWeight="Bold"
                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                        <TextBlock x:Name="EndDetailText" Opacity="0.75" HorizontalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,20"/>
                        <ui:Button x:Name="RematchButton" Content="Rematch" Appearance="Primary"
                                   HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="Rematch_Click"/>
                        <ui:Button Content="Quit to menu" HorizontalAlignment="Stretch" Click="QuitDuel_Click"/>
                        <TextBlock x:Name="EndRematchStatus" Opacity="0.75" HorizontalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,14,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Page>
