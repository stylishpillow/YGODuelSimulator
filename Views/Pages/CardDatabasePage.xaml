<Page x:Class="YGODuelSimulator.Views.Pages.CardDatabasePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      Title="Card Database">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Card Database" FontSize="20" FontWeight="SemiBold"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
            <ui:Button x:Name="ImportButton" Content="Import / Refresh Cards"
                       Appearance="Primary" Icon="{ui:SymbolIcon ArrowDownload24}"
                       Click="ImportButton_Click"/>
            <ui:Button x:Name="ExportSeedButton" Content="Export DB Seed"
                       Margin="8,0,0,0" Icon="{ui:SymbolIcon ArchiveArrowBack24}"
                       Click="ExportSeedButton_Click"
                       ToolTip="Compress the current database to cards.db.gz to commit as the bundled seed."/>
            <TextBlock x:Name="CountText" VerticalAlignment="Center" Margin="16,0,0,0"
                       Text="Cards in database: —"/>
        </StackPanel>

        <TextBlock Grid.Row="2" x:Name="StatusText" Margin="0,12,0,0"
                   TextWrapping="Wrap" Text="Ready."/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
            <TextBlock Text="Card name:" VerticalAlignment="Center"/>
            <ui:TextBox x:Name="CardNameBox" Width="260" Margin="8,0"
                        PlaceholderText="e.g. Pot of Greed"
                        KeyDown="CardNameBox_KeyDown"/>
            <ui:Button x:Name="ShowCardButton" Content="Show Card"
                       Appearance="Primary" Icon="{ui:SymbolIcon Search24}"
                       Click="ShowCardButton_Click"/>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="240" CornerRadius="8"
                    BorderBrush="#40808080" BorderThickness="1">
                <Image x:Name="CardImage" Stretch="Uniform"/>
            </Border>
            <TextBlock Grid.Column="1" x:Name="CardDetailsText" Margin="16,0,0,0"
                       TextWrapping="Wrap" VerticalAlignment="Top"
                       Text="Enter a card name and click Show Card."/>
        </Grid>
    </Grid>
</Page>
