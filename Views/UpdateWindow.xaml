<ui:FluentWindow x:Class="YGODuelSimulator.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Assets/app-icon.png"
        Title="Update required — YGO Duel Simulator" Height="300" Width="420">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="YGO Duel Simulator"/>

        <StackPanel Grid.Row="1" Margin="28,4,28,24" VerticalAlignment="Center">
            <TextBlock Text="Update required" FontSize="24" FontWeight="Bold"/>
            <TextBlock x:Name="MessageText" Opacity="0.8" Margin="0,6,0,16" TextWrapping="Wrap"/>

            <ProgressBar x:Name="Progress" Height="6" Minimum="0" Maximum="100" Visibility="Collapsed"/>
            <TextBlock x:Name="StatusText" Opacity="0.7" Margin="0,8,0,0" Visibility="Collapsed"/>
            <TextBlock x:Name="ErrorText" Foreground="#FF6B6B" TextWrapping="Wrap"
                       Margin="0,8,0,0" Visibility="Collapsed"/>

            <ui:Button x:Name="UpdateButton" Content="Update now" Appearance="Primary"
                       HorizontalAlignment="Stretch" Margin="0,18,0,0" Click="Update_Click"/>
            <ui:Button x:Name="QuitButton" Content="Quit" HorizontalAlignment="Stretch"
                       Margin="0,8,0,0" Click="Quit_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
