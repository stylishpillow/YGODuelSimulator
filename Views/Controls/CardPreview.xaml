<UserControl x:Class="YGODuelSimulator.Views.Controls.CardPreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="500" d:DesignWidth="260">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,8,0">
            <Image x:Name="PreviewImage" Stretch="Uniform" MaxHeight="380"
                   HorizontalAlignment="Left" Margin="0,0,0,10"/>
            <TextBlock x:Name="PreviewName" FontSize="16" FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Text="Click a card to inspect it."/>
            <TextBlock x:Name="PreviewMeta" Opacity="0.8" TextWrapping="Wrap" Margin="0,4,0,8"/>
            <TextBlock x:Name="PreviewText" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
