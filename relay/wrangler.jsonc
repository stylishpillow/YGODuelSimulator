{
  // Cloudflare Worker + Durable Object relay. Free plan compatible: the Durable
  // Object uses the SQLite storage backend (required for free-tier DOs), even
  // though this relay stores nothing.
  "name": "ygo-duel-relay",
  "main": "src/relay.js",
  "compatibility_date": "2025-06-01",
  "durable_objects": {
    "bindings": [
      { "name": "ROOM", "class_name": "RoomRelay" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["RoomRelay"] }
  ]
}
